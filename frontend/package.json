{
  "name": "mddweb",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "e2e": "ng run mddweb:e2e",
    "e2e:ci": "ng run mddweb:e2e-ci",
    "e2e:coverage": "npx nyc report --reporter=lcov --reporter=text-summary",
    "lint": "ng lint",
    "format": "prettier . --write"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ng-icons/core": "^33.1.0",
    "@ng-icons/lucide": "^33.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@cypress/code-coverage": "^4.0.3",
    "@cypress/schematic": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "21.3.0",
    "cypress": "^15.14.2",
    "eslint": "^10.0.2",
    "istanbul-lib-coverage": "^3.2.2",
    "jsdom": "^28.0.0",
    "nyc": "^18.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
